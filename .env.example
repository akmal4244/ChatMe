APP_NAME=ChatMe
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
CHATME_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=ms
APP_FALLBACK_LOCALE=ms
APP_FAKER_LOCALE=ms_MY

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional: only set these when intentionally provisioning an administrator.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Official ChatMe chatbot shown on the homepage.
CHATME_HOMEPAGE_CHATBOT_SLUG=chatme-homepage
CHATME_HOMEPAGE_CHATBOT_DOMAINS=chatme.akmalmarvis.com
CHATME_HOMEPAGE_LEGACY_CHATBOT_ID=

# Quota reservations expire safely if a provider request is interrupted.
CHATME_QUOTA_RESERVATION_TTL_SECONDS=120
CHATME_TESTER_DAILY_AI_LIMIT=20

# Absolute production guardrails for account and knowledge growth.
CHATME_CHATBOT_ABSOLUTE_LIMIT=50
CHATME_KNOWLEDGE_ABSOLUTE_LIMIT=5000
CHATME_KNOWLEDGE_MATCH_CANDIDATE_LIMIT=250

# Shared owner hard caps across public widget and Developer API traffic.
CHATME_OWNER_MESSAGE_PER_MINUTE=600
CHATME_OWNER_MESSAGE_DAILY=5000

# Authenticated chatbot creation abuse control.
CHATME_CHATBOT_CREATIONS_PER_HOUR=10

# Developer API abuse controls. The daily token cap also applies to unlimited plans.
CHATME_DEVELOPER_API_IP_PER_MINUTE=60
CHATME_DEVELOPER_API_TOKEN_PER_MINUTE=180
CHATME_DEVELOPER_API_TOKEN_DAILY=5000

# Public widget ticket and layered abuse controls.
CHATME_WIDGET_TICKET_TTL_SECONDS=600
CHATME_WIDGET_BOOTSTRAP_PER_MINUTE=30
CHATME_WIDGET_INGRESS_IP_PER_MINUTE=60
CHATME_WIDGET_INGRESS_BOT_PER_MINUTE=600
CHATME_WIDGET_TICKET_PER_MINUTE=10
CHATME_WIDGET_CHATBOT_IP_PER_MINUTE=30
CHATME_WIDGET_BOT_PER_MINUTE=180
CHATME_WIDGET_BOT_DAILY_UNLIMITED=5000

# Optional grounded AI fallback. Keep credentials outside version control.
CHATME_AI_ENABLED=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/qwen/qwen3-30b-a3b-fp8
CLOUDFLARE_AI_TIMEOUT=8
CLOUDFLARE_AI_MAX_TOKENS=220

# ToyyibPay monthly renewal (keep credentials outside version control).
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_SANDBOX=false
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
TOYYIBPAY_DNQR_ENABLED=false
TOYYIBPAY_TIMEOUT=15
