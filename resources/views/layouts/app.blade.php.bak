    <style>
        :root { --brand: #4F46E5; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Plus Jakarta Sans', -apple-system, sans-serif; -webkit-font-smoothing: antialiased; }
        .toast{position:fixed;bottom:24px;right:24px;z-index:99999;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:600;box-shadow:0 8px 30px rgba(0,0,0,0.15);opacity:0;transform:translateY(16px);transition:all .3s ease;pointer-events:none;max-width:360px}
        .toast.show{opacity:1;transform:translateY(0)}.toast.success{background:#059669;color:#fff}.toast.error{background:#DC2626;color:#fff}
        #back-to-top{position:fixed;bottom:90px;right:24px;z-index:99990;width:40px;height:40px;border-radius:50%;background:#4F46E5;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transform:scale(.8);transition:all .25s ease;border:none;font-size:16px;box-shadow:0 4px 14px rgba(79,70,229,.3)}
        #back-to-top.visible{opacity:1;transform:scale(1)}#back-to-top:hover{transform:scale(1.08)}#back-to-top:active{transform:scale(.95)}
        #skip-link{position:absolute;top:-100px;left:16px;z-index:99999;background:#1f2937;color:#fff;padding:8px 16px;border-radius:8px;font-size:14px;font-weight:600;transition:top .2s}
        #skip-link:focus{top:16px}
        .skeleton{background:linear-gradient(90deg,#e5e7eb 25%,#f3f4f6 50%,#e5e7eb 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:8px}
        @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
        @media(max-width:768px){.sidebar{transform:translateX(-100%);transition:transform .25s ease;position:fixed;z-index:40}.sidebar.open{transform:translateX(0)}}
    </style>
    <script>
        function showToast(m,t){var e=document.createElement('div');e.className='toast '+(t||'success');e.textContent=m;document.body.appendChild(e);requestAnimationFrame(function(){e.classList.add('show')});setTimeout(function(){e.classList.remove('show');setTimeout(function(){e.remove()},300)},3500)}
        function toggleDark(){var h=document.documentElement;h.classList.toggle('dark');localStorage.setItem('theme',h.classList.contains('dark')?'dark':'light');var b=document.getElementById('dark-toggle');if(b)b.innerHTML=h.classList.contains('dark')?'\u2600':'\u263D'}
        document.addEventListener('DOMContentLoaded',function(){if(localStorage.getItem('theme')==='dark'||(!localStorage.getItem('theme')&&matchMedia('(prefers-color-scheme:dark)').matches))document.documentElement.classList.add('dark');var b=document.getElementById('dark-toggle');if(b)b.innerHTML=document.documentElement.classList.contains('dark')?'\u2600':'\u263D';var t=document.getElementById('back-to-top');if(t){window.addEventListener('scroll',function(){t.classList.toggle('visible',window.scrollY>400)});t.addEventListener('click',function(){window.scrollTo({top:0,behavior:'smooth'})})}})
    </script>
</head>
